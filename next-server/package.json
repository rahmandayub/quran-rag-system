{
  "name": "next-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_TLS_REJECT_UNAUTHORIZED=0 dotenv -e .env.local -- next dev",
    "build": "NODE_TLS_REJECT_UNAUTHORIZED=0 dotenv -e .env.local -- next build",
    "start": "NODE_TLS_REJECT_UNAUTHORIZED=0 dotenv -e .env.local -- next start",
