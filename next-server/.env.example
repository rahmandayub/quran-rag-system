# Server Configuration
PORT=4000

# Qdrant Configuration
QDRANT_HOST=localhost
QDRANT_PORT=6335
QDRANT_COLLECTION_NAME=quran_verses_enhanced
QDRANT_HADITH_COLLECTION_NAME=hadith_collection
DISTANCE_METRIC=Cosine

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
# Ollama embedding model (can be changed to any Ollama embedding model)
# Examples: qwen3-embedding:0.6b, nomic-embed-text, mxbai-embed-large
OLLAMA_EMBEDDING_MODEL=qwen3-embedding:0.6b

# Embedding dimension (must match the model's output dimension)
# qwen3-embedding:0.6b produces 1024-dimensional vectors
# qwen3-embedding:1.5b produces 1536-dimensional vectors
# nomic-embed-text produces 768-dimensional vectors
# mxbai-embed-large produces 1024-dimensional vectors
EMBEDDING_DIMENSION=1024

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=coder-model
OPENAI_BASE_URL=https://qwen.alitlab.com/v1

# Surah Context Configuration (for enhanced RAG with full surah context)
MAX_SURAHS_TO_INCLUDE=5
SURAH_CONTEXTS_PATH=./data/surah-contexts.json

# Prisma Database URL (for authentication)
# PostgreSQL connection string format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/your_database

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:4000
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32

# OAuth Providers (optional - configure when needed)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
