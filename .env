# Qdrant Configuration Environment Variables
# Copy this file to .env and adjust values as needed

# Qdrant host (used for client connections)
QDRANT_HOST=localhost

# Qdrant REST API port
QDRANT_PORT=6335

# Qdrant gRPC API port (for high-performance clients)
QDRANT_GRPC_PORT=6336

# Collection name for Quran verses
QDRANT_COLLECTION_NAME=quran_verses

# Distance metric for similarity search
# Options: Cosine, Dot, Euclid
DISTANCE_METRIC=Cosine

# Qdrant collection name for hadith
QDRANT_HADITH_COLLECTION_NAME=hadith_collection

# Ollama embedding model (can be changed to any Ollama embedding model)
# Examples: qwen3-embedding:0.6b, nomic-embed-text, mxbai-embed-large
OLLAMA_EMBEDDING_MODEL=qwen3-embedding:0.6b

# Embedding dimension (must match the model's output dimension)
# qwen3-embedding:0.6b produces 1024-dimensional vectors
# qwen3-embedding:1.5b produces 1536-dimensional vectors
# nomic-embed-text produces 768-dimensional vectors
# mxbai-embed-large produces 1024-dimensional vectors
EMBEDDING_DIMENSION=1024